[
  {
    "id": "git-pull",
    "name": "Git Pull",
    "icon": "git-branch",
    "description": "拉取当前分支最新代码",
    "type": "shell",
    "command": "git pull",
    "workingDir": "~",
    "timeoutMs": 60000,
    "params": [],
    "enabled": true,
    "sortOrder": 0
  },
  {
    "id": "git-status",
    "name": "Git Status",
    "icon": "terminal",
    "description": "查看当前分支状态",
    "type": "shell",
    "command": "git status",
    "workingDir": "~",
    "params": [],
    "enabled": true,
    "timeoutMs": 60000,
    "sortOrder": 0
  },
  {
    "id": "ee-apply-branch",
    "name": "EE Apply Branch",
    "icon": "zap",
    "description": "为 EE 项目申请分支",
    "type": "shell",
    "command": "node ~/work/brain/scripts/ee-branch-apply.js {{issueId}} {{summary}} {{engineeringKeyword}}",
    "workingDir": "~/work/brain",
    "params": [
      {
        "name": "issueId",
        "label": "需求 ID 或 URL",
        "type": "text",
        "required": true
      },
      {
        "name": "summary",
        "label": "分支摘要",
        "type": "text",
        "required": true
      },
      {
        "name": "engineeringKeyword",
        "label": "工程搜索关键词",
        "type": "text",
        "required": false,
        "default": ""
      }
    ],
    "enabled": true,
    "timeoutMs": 60000,
    "sortOrder": 0
  },
  {
    "id": "replace-p7b",
    "name": "Replace P7B",
    "icon": "file-code",
    "description": "替换 harmonyajkproject 的 debug p7b 签名文件并提交推送",
    "type": "shell",
    "command": "bash scripts/replace-p7b.sh {{sourceP7b}} {{branch}}",
    "workingDir": "~/work/quicktools",
    "params": [
      {
        "name": "sourceP7b",
        "label": "源 p7b 文件路径",
        "type": "text",
        "required": true
      },
      {
        "name": "branch",
        "label": "目标分支（留空自动获取最新 release）",
        "type": "text",
        "required": false,
        "default": ""
      }
    ],
    "enabled": true,
    "timeoutMs": 300000,
    "sortOrder": 0
  },
  {
    "id": "open-brain",
    "name": "打开 Brain 项目",
    "icon": "folder-open",
    "description": "用 VSCode 打开 brain 项目",
    "type": "open",
    "command": "code ~/work/brain",
    "params": [],
    "enabled": true,
    "timeoutMs": 60000,
    "workingDir": "~",
    "sortOrder": 0
  },
  {
    "id": "open-logs-page",
    "name": "打开日志页面",
    "icon": "list",
    "description": "切换到日志页面",
    "type": "notification",
    "command": "打开日志页面",
    "params": [],
    "enabled": true,
    "timeoutMs": 60000,
    "workingDir": "~",
    "sortOrder": 0
  }
]
