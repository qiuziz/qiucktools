[
  {
    "id": "git-pull",
    "name": "Git Pull",
    "icon": "git-branch",
    "description": "拉取当前分支最新代码",
    "type": "shell",
    "command": "git pull",
    "workingDir": "~",
    "timeoutMs": 60000,
    "params": [],
    "enabled": true,
    "sortOrder": 0
  },
  {
    "id": "git-status",
    "name": "Git Status",
    "icon": "terminal",
    "description": "查看当前分支状态",
    "type": "shell",
    "command": "git status",
    "workingDir": "~",
    "params": [],
    "enabled": true,
    "timeoutMs": 60000,
    "sortOrder": 0
  },
  {
    "id": "ee-apply-branch",
    "name": "EE Apply Branch",
    "icon": "zap",
    "description": "为 EE 项目申请分支",
    "type": "shell",
    "command": "node ~/work/brain/scripts/ee-branch-apply.js {{issueId}} {{summary}} {{engineeringKeyword}}",
    "workingDir": "~/work/brain",
    "params": [
      {
        "name": "issueId",
        "label": "需求 ID 或 URL",
        "type": "text",
        "required": true
      },
      {
        "name": "summary",
        "label": "分支摘要",
        "type": "text",
        "required": true
      },
      {
        "name": "engineeringKeyword",
        "label": "工程搜索关键词",
        "type": "text",
        "required": false,
        "default": ""
      }
    ],
    "enabled": true,
    "timeoutMs": 60000,
    "sortOrder": 0
  },
  {
    "id": "replace-p7b",
    "name": "Replace P7B",
    "icon": "file-code",
    "description": "通过 GitLab CLI 远程替换 harmonyajkproject 的 debug p7b 签名文件",
    "type": "shell",
    "command": "bash scripts/replace-p7b.sh {{sourceP7b}} {{branch}}",
    "workingDir": "~/work/quicktools",
    "params": [
      {
        "name": "sourceP7b",
        "label": "源 p7b 文件路径",
        "type": "text",
        "required": true
      },
      {
        "name": "branch",
        "label": "目标分支（留空自动获取最新 release）",
        "type": "text",
        "required": false,
        "default": ""
      }
    ],
    "enabled": true,
    "timeoutMs": 300000,
    "sortOrder": 0
  },
  {
    "id": "harmony-webview-devtools-ajk",
    "name": "AJK WebView DevTools",
    "icon": "terminal",
    "description": "将安居客 Harmony WebView DevTools 转发到本机 9222 端口",
    "type": "shell",
    "command": "bash scripts/chromedev.sh anjuke",
    "workingDir": "~/work/quicktools",
    "params": [],
    "enabled": true,
    "timeoutMs": 60000,
    "sortOrder": 0
  },
  {
    "id": "harmony-webview-devtools-wuba",
    "name": "Wuba WebView DevTools",
    "icon": "terminal",
    "description": "将 58 同城 Harmony WebView DevTools 转发到本机 9222 端口",
    "type": "shell",
    "command": "bash scripts/chromedev.sh wuba",
    "workingDir": "~/work/quicktools",
    "params": [],
    "enabled": true,
    "timeoutMs": 60000,
    "sortOrder": 0
  },
  {
    "id": "miniapp-host-update-dev-mps",
    "name": "更新小程序宿主分包",
    "icon": "file-code",
    "description": "更新 miniapp-host 的 dev.mps.json，并提交推送",
    "type": "shell",
    "command": "bash scripts/dev-mps.sh -p {{packageName}} -v {{version}}",
    "workingDir": "~/work/quicktools",
    "params": [
      {
        "name": "packageName",
        "label": "MPS 包名或匹配关键词",
        "type": "text",
        "required": true
      },
      {
        "name": "version",
        "label": "版本号或版本标识",
        "type": "text",
        "required": true
      }
    ],
    "enabled": true,
    "timeoutMs": 300000,
    "sortOrder": 0
  },
  {
    "id": "miniapp-host-start-integration",
    "name": "拉取小程序集成版本",
    "icon": "terminal",
    "description": "运行 miniapp-host 集成预览模式，拉取当前集成 MPS 包版本",
    "type": "shell",
    "command": "zsh -lc \"pnpm start {{miniapp}}\"",
    "workingDir": "~/work/brain/projects/miniapp-host/code",
    "params": [
      {
        "name": "miniapp",
        "label": "小程序宿主",
        "type": "select",
        "required": true,
        "default": "anjuke_weapp",
        "options": [
          { "value": "anjuke_weapp", "label": "安居客微信" },
          { "value": "anjuke_weapp_plugin", "label": "安居客微信插件" },
          { "value": "anjuke_alipay", "label": "安居客支付宝" },
          { "value": "anjuke_swan", "label": "安居客百度" },
          { "value": "anjuke_tt", "label": "安居客抖音" },
          { "value": "anjuke_kwai", "label": "安居客快手" },
          { "value": "wuba_weapp", "label": "58房产微信" },
          { "value": "tongcheng_weapp", "label": "58同城微信" }
        ]
      }
    ],
    "enabled": true,
    "timeoutMs": 600000,
    "sortOrder": 0
  },
